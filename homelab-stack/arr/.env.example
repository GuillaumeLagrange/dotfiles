# WireGuard Configuration
WG_CONF_PATH=/path/to/wireguard/config
WG_GATEWAY=your_wireguard_gateway

# Timezone
TZ=Europe/Paris

# User ID and Group ID
# They need acess to the media dir and downloads dir below
UID=1000
GID=1000

# Downloads Directory Path
DOWNLOADS_DIR_PATH=/path/to/downloads

# Media Directory Path
MEDIA_DIR_PATH=/path/to/media

# Jellyfin url for autodiscovery (UDP stuff)
JELLYFIN_URL=https://jellyfin.example.com

# Transmission user / password
TRANSMISSION_USER=user
TRANSMISSION_PASS=pass
